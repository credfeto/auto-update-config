{
  "general": {
    "files": {
      ".ai-instructions": "AI Instructions",
      ".editorconfig": "Editor Config",
      ".globalconfig": "Global Config",
      ".csharpierrc": "CSharpier Config",
      ".csharpierrc.json": "CSharpier Config",
      ".csharpierrc.yaml": "CSharpier Config",
      ".gitleaks.toml": "Gitleaks Config",
      ".gitignore": "Gitignore config",
      ".gitattributes": "git file attributes config",
      ".sqlfluff": "SQLFluff Lint Config",
      ".tsqllintrc": "SQL Lint Config",
      "CLAUDE.md": "Claude Instructions",
      "CONTRIBUTING.md": "Documentation",
      "SECURITY.md": "Documentation"
    },
    "mirror-folders": {
      ".github/instructions": "Config",
      "ai/global": "AI"
    },
    "partial-files": {
      "ai/local/index.md": {
        "type": "AI",
        "match": {
          "begin": "<!-- Globally Maintained -->",
          "end": "<!-- Locally Maintained -->"
        }
      }
    }
  },
  "dotNet": {
    "global-json": true,
    "resharper-dotsettings": true,
    "files": {
      "Directory.Build.props": "C# Directory Build Properties",
      "UnitTests.props": "C# Unit test Build Properties",
      "pre-release.rule-settings.json": "Code analysis - pre-release rule overrides",
      "release.rule-settings.json": "Code analysis - release rule overrides"
    }
  },
  "gitHub": {
    "dependabot": {
      "generate": true
    },
    "labels": {
      "generate": true
    },
    "issue-templates": true,
    "pr-template": true,
    "actions": true,
    "linters": true,
    "files": {
      "pr-lint.yml": "Linters",
      "CODEOWNERS": "Code owners",
      "FUNDING.yml": "Funding config"
    }
  },
  "cleanup": {
    "files": {
      "src/CodeAnalysis.ruleset": "Obsolete C# Ruleset",
      ".github/actions/nuget-push-integrated-symbol-feed/actions.yml": "Obsolete action",
      ".github/actions/nuget-push-separate-symbol-feed/actions.yml": "Obsolete action",
      ".github/workflows/oss-scorecared.yml": "Obsolete action",
      ".github/workflows/reformat-sql.yml": "Obsolete action",
      ".github/workflows/reformat-yaml.yml": "Obsolete action",
      ".github/workflows/todos.yml": "Obsolete action",
      ".github/actions/build-check/actions.yml": "Obsolete action",
      ".github/workflows/merge-dependabot.yml": "Replaced by approve-dependabot.yml native auto-merge"
    }
  }
}
